{
  "name": "retirement-calculator-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @retirement/web",
    "build": "npm run build -w @retirement/calc && npm run build -w @retirement/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "preview": "npm run preview -w @retirement/web"
  }
}
